NODE_ENV=production
PORT=3000
CORS_ORIGIN=*
JWT_SECRET=change_me_long_random_secret

# Development fallback
DB_PATH=./data/nyx.db

# Production database
DB_DRIVER=postgres
DATABASE_URL=postgres://nyx:nyx_password@postgres:5432/nyx
PG_POOL_SIZE=20
PG_SSL=false

# Redis + queues + socket scaling
REDIS_URL=redis://redis:6379
QUEUE_ATTEMPTS=5
WORKER_CONCURRENCY=5

# S3 / MinIO media storage
S3_BUCKET=nyx-media
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=nyx_minio
S3_SECRET_ACCESS_KEY=nyx_minio_password
CDN_BASE_URL=http://localhost:9000/nyx-media
MAX_UPLOAD_MB=200

# Push
EXPO_ACCESS_TOKEN=
FCM_SERVER_KEY=
APNS_KEY_ID=

# Calls / TURN
TURN_URL=turn:turn.example.com:3478
TURN_USERNAME=nyx
TURN_CREDENTIAL=change_me

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
ANTISPAM_WINDOW_MS=10000
ANTISPAM_MAX_WRITES=35
IP_HASH_SALT=change_me

# Backups
BACKUP_DIR=./backups
PRODUCTION_REQUIRED_SERVICES=postgres,redis,storage

# Performance / production tuning
TRUST_PROXY=1
JSON_LIMIT=2mb
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
SLOW_REQUEST_MS=750
STATIC_MAX_AGE=7d
STATIC_IMMUTABLE=false
SQLITE_OPTIMIZE_INTERVAL_MS=600000
FORCE_SHUTDOWN_MS=10000
WEB_CONCURRENCY=max
MAX_MEMORY_RESTART=512M
